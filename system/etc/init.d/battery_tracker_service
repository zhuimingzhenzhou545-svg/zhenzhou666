#!/system/bin/sh
# Battery Tracker Service
# Start battery tracking in background

LOG_FILE="/sdcard/BatteryTracker/log.txt"
PID_FILE="/dev/battery_tracker.pid"

# Create log directory if not exists
mkdir -p /sdcard/BatteryTracker

# Check if already running
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        exit 0
    fi
fi

# Start tracking in background
nohup /system/bin/battery_tracker.sh > /dev/null 2>&1 &

# Write PID
echo $! > "$PID_FILE"